{
  "config": {
    "wide_screen_mode": true
  },
  "header": {
    "title": {
      "tag": "plain_text",
      "content": "⚠️ 经营预警通知"
    },
    "template": "red"
  },
  "elements": [
    {
      "tag": "div",
      "text": {
        "tag": "lark_md",
        "content": "**门店：** {{storeName}}\n**时间：** {{dateTime}}\n**负责人：** {{managerName}}"
      }
    },
    {
      "tag": "hr"
    },
    {
      "tag": "div",
      "text": {
        "tag": "lark_md",
        "content": "**预警类型：** {{warningType}}\n**当前值：** {{currentValue}}\n**预警阈值：** {{threshold}}\n**变化幅度：** {{changeRate}}"
      }
    },
    {
      "tag": "hr"
    },
    {
      "tag": "div",
      "text": {
        "tag": "lark_md",
        "content": "**建议处理措施：**\n{{suggestions}}"
      }
    },
    {
      "tag": "action",
      "actions": [
        {
          "tag": "button",
          "text": {
            "tag": "plain_text",
            "content": "✅ 已处理"
          },
          "type": "primary",
          "value": {
            "action": "mark_handled",
            "warning_id": "{{warningId}}",
            "store_id": "{{storeId}}"
          }
        },
        {
          "tag": "button",
          "text": {
            "tag": "plain_text",
            "content": "📊 查看详情"
          },
          "type": "default",
          "value": {
            "action": "view_warning_detail",
            "warning_id": "{{warningId}}"
          }
        },
        {
          "tag": "button",
          "text": {
            "tag": "plain_text",
            "content": "忽略"
          },
          "type": "default",
          "value": {
            "action": "ignore_warning",
            "warning_id": "{{warningId}}"
          }
        }
      ]
    }
  ]
}
