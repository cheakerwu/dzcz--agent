# ==================== 点之出众餐饮智能工作台 配置 ====================

# Web 服务端口
PORT=3008

# 运行环境（开发环境改为 development）
NODE_ENV=production

# 访问密码（推荐设置，留空则无需密码）
ACCESS_PASSWORD=

# JWT 密钥（必须修改为强密码！用于 Web 模式的身份验证）
JWT_SECRET=change-this-to-a-random-secret-string

# 开启 Docker 模式标识
DEEPBOT_DOCKER=true

# ==================== AI 模型配置（Docker 环境，桌面版无需配置）====================
# 仅 Docker 部署时使用，桌面版（Mac/Windows）通过 UI 界面配置
# 优先级：系统页面配置 > 环境变量配置
# 首次部署可通过环境变量初始化，之后可在 UI 中修改

# API Key（必填）
AI_API_KEY=

# API 地址（Base URL，必填）
# OpenAI 兼容：https://api.openai.com/v1
# 通义千问：https://dashscope.aliyuncs.com/compatible-mode/v1
# DeepSeek：https://api.deepseek.com/v1
# Google Gemini：https://generativelanguage.googleapis.com/v1beta
AI_BASE_URL=

# 主模型 ID（必填）
# Qwen：qwen-max / qwen-plus
# DeepSeek：deepseek-chat
# Gemini：gemini-2.5-pro-preview
# OpenAI：gpt-4o
AI_MODEL_ID=

# API 类型（必填）
# openai-completions  → OpenAI 兼容格式（Qwen、DeepSeek、OpenAI、OpenRouter 等）
# google-generative-ai → Google Gemini 原生格式
# anthropic-messages  → Anthropic Claude 格式
AI_API_TYPE=openai-completions

# 快速模型 ID（可选，用于轻量级任务）
# AI_MODEL_ID_2=

# ==================== 数据持久化目录（可选）====================
# 以下路径为宿主机路径，会被挂载到容器内的 /data/* 目录
# 不设置则使用默认路径（由 docker-compose.yml 中的 volumes 决定）
# 修改后需要重启容器：docker-compose down && docker-compose up -d

# 工作目录（AI 文件操作的根目录）
# WORKSPACE_DIR=~

# Skill 安装目录
# SKILLS_DIR=~/.agents/skills

# 记忆文件目录
# MEMORY_DIR=~/.deepbot/memory

# 对话历史目录
# SESSIONS_DIR=~/.deepbot/sessions

# 脚本目录（AI 生成的脚本文件）
# SCRIPTS_DIR=~/.deepbot/scripts

# 图片生成目录（AI 生成的图片文件）
# IMAGES_DIR=~/.deepbot/images

# 数据库目录（SQLite 文件）
# DB_DIR=~/.deepbot

# ==================== 餐饮运营扩展配置（预留）====================
# 以下配置项为餐饮运营场景预留，后续开发时启用

# 外卖平台账号配置（预留）
# MEITUAN_SHOP_ID=
# ELEME_SHOP_ID=

# 飞书机器人配置（用于发送运营报告）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# 企业微信配置（用于发送运营报告）
# WECOM_CORP_ID=
# WECOM_APP_SECRET=

# 数据采集定时任务配置（预留）
# DAILY_REPORT_CRON=0 9 * * *
# WEEKLY_REPORT_CRON=0 10 * * 1
